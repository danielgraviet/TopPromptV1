{
  "name": "@toprompt/extension",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@toprompt/types": "workspace:*",
    "@toprompt/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "plasmo": "^0.90.5",
    "@types/chrome": "^0.0.284"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "TopPrompt",
    "description": "TopPrompt browser extension",
    "version": "0.0.1",
    "permissions": ["activeTab", "storage"],
    "action": {
      "default_title": "TopPrompt"
    }
  }
}
